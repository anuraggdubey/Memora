# =============================================================================
# Memora — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# AI Models
# -----------------------------------------------------------------------------

# Grok API — Primary model for fast, low-latency responses
# Get your key at: https://console.groq.com/
GROQ_API_KEY=

# Google Gemini Flash — Secondary model for deep reasoning and long context
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase (Database + Auth)
# -----------------------------------------------------------------------------

# Your Supabase project URL (public, safe for browser)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anonymous/public key (public, safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase service role key (SECRET — server-side only)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------

# Resend API key for weekly digest emails
# Get your key at: https://resend.com/
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Secret used to authenticate Vercel Cron job requests
CRON_SECRET=
